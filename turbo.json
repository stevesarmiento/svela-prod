{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "stream",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "env": [
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "CONVEX_DEPLOYMENT",
        "CLERK_FRONTEND_API_URL",
        "CLERK_SIGNING_KEY",
        "CLERK_SECRET_KEY",
        "GEMINI_API_KEY",
        "XAI_API_KEY",
        "OPENAI_API_KEY",
        "GG_API_KEY",
        "BIRDEYE_API_KEY",
        "CG_API_KEY",
        "X_CG_PRO_API_KEY",
        "COINMARKETCAP_API_KEY",
        "PRIVY_SECRET",
        "PRIVY_APP_ID",
        "X_CAPI_API_KEY",
        "V0_API_KEY",
        "API_ENCRYPTION_KEY",
        "INTERNAL_CONVEX_SERVER_TOKEN"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "next-env.d.ts", ".expo/**"]
    },
    "dev": {
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "persistent": true,
      "cache": false
    },
    "dev:convex": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^topo"]
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": ["**/*.tsbuildinfo"]
    }
  },
  "globalEnv": ["NODE_ENV"]
}
