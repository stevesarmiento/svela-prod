{
  "name": "@armadura",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "description": "Arma Web3 components and utilities for Solana development",
  "scripts": {
    "clean": "rm -rf .turbo node_modules && turbo clean --filter=@armadura/*",
    "lint": "turbo lint --filter=@armadura/*",
    "format": "turbo format --filter=@armadura/*",
    "typecheck": "turbo typecheck --filter=@armadura/*"
  },
  "exports": {
    "./connector": "./connector/src/index.ts",
    "./sdk": "./sdk/src/index.ts",
    "./jupiter": "./jupiter/src/index.ts",
    "./titan": "./titan/src/index.ts",
    "./providers": "./providers/src/index.ts"
  },
  "dependencies": {
    "@armadura/sdk": "0.1.5",
    "@armadura/jupiter": "0.1.5",
    "@armadura/titan": "0.1.0",
    "@armadura/providers": "0.1.5"
  },
  "peerDependencies": {
    "@armadura/connector": "0.1.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
