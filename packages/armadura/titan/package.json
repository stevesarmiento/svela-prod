{
  "name": "@armadura/titan",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "biome check .",
    "format": "biome --write .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@armadura/sdk": "workspace:*"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2"
  },
  "devDependencies": {
    "@armadura/sdk": "workspace:*",
    "@solana/kit": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.3"
  }
}
