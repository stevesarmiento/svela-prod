{
  "name": "v1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/analytics",
    "packages/convex",
    "packages/email",
    "packages/jobs",
    "packages/kv",
    "packages/logger",
    "packages/ui",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "dev": "turbo run dev --filter=!@v1/api",
    "dev:web": "turbo run dev --filter=@v1/web",
    "dev:jobs": "turbo run jobs --filter=@v1/jobs",
    "dev:app": "turbo run dev --filter=@v1/app",
    "dev:convex": "bunx convex dev",
    "start:web": "turbo run start --filter=@v1/web",
    "start:app": "turbo run start --filter=@v1/app",
    "test": "turbo run test",
    "format": "biome format --write .",
    "lint": "turbo run lint && bun lint:repo",
    "lint:repo": "bunx sherif@latest",
    "lint:repo:fix": "bunx sherif@latest --fix",
    "typecheck": "turbo run typecheck",
    "dev:with-api": "turbo run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@v1/typescript": "workspace:*",
    "turbo": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.1.26",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=8.0.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@sentry/cli",
    "protobufjs"
  ],
  "dependencies": {
    "latest": "^0.2.0"
  }
}
